{
  "embedding": {
    "provider": "ollama",
    "baseUrl": "http://127.0.0.1:11434/api",
    "model": "embeddinggemma",
    "timeoutMs": 60000,
    "documentPrefix": "search_document: ",
    "queryPrefix": "search_query: "
  },
  "indexing": {
    "includeExtensions": [
      ".ts",
      ".tsx",
      ".js",
      ".jsx",
      ".mjs",
      ".cjs",
      ".py",
      ".java",
      ".go",
      ".md",
      ".mdx",
      ".c",
      ".h",
      ".cpp",
      ".cc",
      ".cxx",
      ".hpp",
      ".hxx",
      ".cs",
      ".aspx",
      ".razor",
      ".cshtml",
      ".json",
      ".html",
      ".htm",
      ".css",
      ".xml",
      ".csproj",
      ".sln",
      ".rs",
      ".rb",
      ".kt",
      ".kts",
      ".swift",
      ".tex",
      ".pdf",
      ".docx",
      ".doc",
      ".xls",
      ".xlsx"
    ],
    "excludeDirs": [
      "node_modules",
      ".git",
      ".opencode",
      "dist",
      "build",
      "__pycache__",
      ".venv"
    ],
    "chunkOverlap": 0,
    "minFileSizeBytes": 0
  },
  "vectorStore": {
    "path": "./.opencode/rag_db"
  },
  "retrieval": {
    "topK": 20,
    "minScore": 0.1,
    "hybridSearch": {
      "enabled": true,
      "keywordWeight": 0.4
    }
  },
  "openCode": {
    "enabled": true,
    "maxContextChunks": 20,
    "readOverride": true,
    "autoIndex": {
      "enabled": false,
      "debounceMs": 2000,
      "intervalMs": 300000
    },
    "autoInject": {
      "enabled": true,
      "minScore": 0.75,
      "maxChunks": 10,
      "maxTokens": 2000
    }
  },
  "description": {
    "enabled": false,
    "provider": "ollama",
    "baseUrl": "http://127.0.0.1:11434/api",
    "model": "qwen2.5:3b",
    "timeoutMs": 60000,
    "systemPrompt": "Describe code for embedding search. Output must be caveman style: short simple words, rough grammar. Include what code do, main names, data in, data out, side effects, errors, and search words. No markdown, no code. No line-by-line talk. If user message contains multiple chunks labeled === CHUNK N ===, describe each one separately, starting each with CHUNK N: followed by the description. For a single chunk, give the description directly."
  },
  "logging": {
    "level": "debug",
    "logFilePath": "./.opencode/opencode-rag.log"
  }
}

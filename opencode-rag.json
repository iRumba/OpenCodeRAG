{
  "embedding": {
    "provider": "ollama",
    "baseUrl": "http://127.0.0.1:11434/api",
    "model": "embeddinggemma:latest",
    "timeoutMs": 30000
  },
  "indexing": {
    "minFileSizeBytes": 0,
    "includeExtensions": [
      ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs",
      ".py", ".java", ".go",
      ".md", ".mdx",
      ".c", ".h", ".cpp", ".cc", ".cxx", ".hpp", ".hxx",
      ".cs", ".aspx", ".razor", ".cshtml",
      ".json",
      ".html", ".htm", ".css",
      ".xml", ".csproj", ".sln",
      ".rs", ".rb", ".kt", ".kts", ".swift"
    ],
    "excludeDirs": [".opencode", "node_modules", ".git", "dist", "build", "__pycache__", ".venv"],
    "chunkOverlap": 0
  },
  "vectorStore": {
    "path": "./.opencode/rag_db"
  },
  "retrieval": {
    "topK": 10
  },
  "openCode": {
    "enabled": true,
    "maxContextChunks": 10,
    "autoIndex": {
      "enabled": true,
      "debounceMs": 2000,
      "intervalMs": 300000
    }
  },
  "logging": {
    "level": "info",
    "logFilePath": "./.opencode/opencode-rag.log"
  }
}

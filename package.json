{
  "name": "opencode-rag-plugin",
  "version": "1.3.2",
  "description": "OpenCode plugin for local-first RAG-based semantic code search",
  "type": "module",
  "main": "./dist/plugin-entry.js",
  "module": "./dist/plugin-entry.js",
  "types": "./dist/plugin-entry.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin-entry.js",
      "require": "./dist/plugin-entry.js",
      "types": "./dist/plugin-entry.d.ts"
    },
    "./server": {
      "import": "./dist/plugin-entry.js",
      "require": "./dist/plugin-entry.js",
      "types": "./dist/plugin-entry.d.ts"
    },
    "./library": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "opencode-rag": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"const fs=require('fs');fs.mkdirSync('dist/types',{recursive:true});fs.copyFileSync('src/types/opencode-plugin.d.ts','dist/types/opencode-plugin.d.ts');\"",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"const {spawnSync}=require('node:child_process');const {globSync}=require('node:fs');const testFiles=globSync('src/**/*.test.ts');if(testFiles.length===0){console.log('No test files found under src; skipping npm test.');process.exit(0);}const result=spawnSync(process.execPath,['--import','tsx','--test','--test-force-exit',...testFiles],{stdio:'inherit'});process.exit(typeof result.status==='number'?result.status:1);\"",
    "cli": "tsx src/cli.ts",
    "release:patch": "node ./scripts/release-patch.js"
  },
  "keywords": [
    "opencode",
    "rag",
    "code-search",
    "embeddings",
    "vector-search",
    "semantic-search",
    "plugin",
    "ai",
    "code"
  ],
  "author": "Christoph Döllinger <christoph.doellinger@med.uni-heidelberg.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrDoe/OpenCodeRAG.git"
  },
  "bugs": {
    "url": "https://github.com/MrDoe/OpenCodeRAG/issues"
  },
  "homepage": "https://github.com/MrDoe/OpenCodeRAG#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@lancedb/lancedb": "^0.29.0",
    "apache-arrow": "18.1.0",
    "canvas": "^3.2.3",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "tree-sitter-wasm": "^1.0.2",
    "web-tree-sitter": "^0.26.9",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.15.5",
    "@opentui/core": "^0.4.0",
    "@opentui/keymap": "^0.4.0",
    "@opentui/solid": "^0.4.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.17",
    "@types/word-extractor": "^1.0.6",
    "solid-js": "^1.9.12",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "web-tree-sitter": "$web-tree-sitter"
  }
}
